{
    "$help": "https://aka.ms/terminal-documentation",
    "$schema": "https://aka.ms/terminal-profiles-schema",
    "actions": [],
    "alwaysShowTabs": true,
    "copyFormatting": "none",
    "copyOnSelect": true,
    "keybindings":
    [
        {
            "id": "Terminal.MoveFocusDown",
            "keys": "ctrl+j"
        },
        {
            "id": "Terminal.MoveFocusUp",
            "keys": "ctrl+k"
        },
        {
            "id": "Terminal.MoveFocusLeft",
            "keys": "ctrl+h"
        },
        {
            "id": "Terminal.MoveFocusRight",
            "keys": "ctrl+l"
        },
        {
            "id": "Terminal.ClosePane",
            "keys": "alt+x"
        },
        {
            "id": "Terminal.SwapPanePreviousInOrder",
            "keys": "alt+]"
        },
        {
            "id": "Terminal.SplitPaneDown",
            "keys": "alt+'"
        },
        {
            "id": "Terminal.SwapPaneNextInOrder",
            "keys": "alt+["
        },
        {
            "id": "Terminal.SplitPaneRight",
            "keys": "alt+v"
        },
        {
            "id": "Terminal.CopyToClipboard",
            "keys": "ctrl+c"
        },
        {
            "id": "Terminal.PasteFromClipboard",
            "keys": "ctrl+v"
        },
        {
            "id": "Terminal.DuplicatePaneAuto",
            "keys": "alt+shift+d"
        }
    ],
    "newTabMenu":
    [
        {
            "type": "remainingProfiles"
        }
    ],
    "profiles":
    {
        "defaults": {
          "bellStyle": "none",
          "cursorShape": "filledBox"
        },
				"list": []
		},
    "schemes": [],
    "showTabsInTitlebar": true,
    "themes": [],
    "windowingBehavior": "useNew"
}
